# Copy to .env for local runs. Leave MONGO_URI empty to use an in-memory MongoDB.
PORT=8080
NODE_ENV=development
ENV_LABEL=dev

# MongoDB (Cosmos DB for MongoDB vCore in Azure)
MONGO_URI=
DB_NAME=didi_dir

# Signs the auth cookie. MUST be set to a long random value in production.
JWT_SECRET=change-me-to-a-long-random-string

# Created automatically on first start when the users collection is empty.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
ADMIN_NAME=מנהל מערכת

# Set to 1 to load demo flock data on startup (non-prod only).
SEED_ON_START=0
